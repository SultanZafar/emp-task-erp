<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Payroll List View -->
    <record id="view_emp_payroll_list" model="ir.ui.view">
        <field name="name">emp.payroll.list</field>
        <field name="model">emp.payroll</field>
        <field name="arch" type="xml">
            <list string="Payroll">
                <field name="employee_id"/>
                <field name="month"/>
                <field name="year"/>
                <field name="salary"/>
                <field name="status"/>
                <field name="payment_date"/>
            </list>
        </field>
    </record>

    <!-- Payroll Form View -->
    <record id="view_emp_payroll_form" model="ir.ui.view">
        <field name="name">emp.payroll.form</field>
        <field name="model">emp.payroll</field>
        <field name="arch" type="xml">
            <form string="Payroll">
                <header>
                    <button name="action_pay_salary"
                            string="Pay Salary"
                            type="object"
                            class="btn-primary"
                            invisible="status =='pAid'"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="unpaid,paid"
                           statusbar_colors='{"paid": "success", "unpaid": "danger"}'/>
                </header>
                <sheet>
                    <group string="Employee Info">
                        <field name="employee_id"/>
                        <field name="month"/>
                        <field name="year"/>
                        <field name="salary"/>
                    </group>
                    <group string="Payment Info">
                        <field name="payment_date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_emp_payroll" model="ir.actions.act_window">
        <field name="name">Payroll</field>
        <field name="res_model">emp.payroll</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>