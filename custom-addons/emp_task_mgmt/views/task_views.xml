<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Task List View -->
    <record id="view_emp_task_list" model="ir.ui.view">
        <field name="name">emp.task.list</field>
        <field name="model">emp.task</field>
        <field name="arch" type="xml">
                <list string="Tasks">
                    <field name="name"/>
                    <field name="assigned_to"/>
                    <field name="deadline"/>
                    <field name="status"/>
                </list>
            </field>
    </record>

    <!-- Kanban View -->
<record id="view_emp_task_kanban" model="ir.ui.view">
    <field name="name">emp.task.kanban</field>
    <field name="model">emp.task</field>
    <field name="arch" type="xml">
        <kanban default_group_by="status">
            <field name="name"/>
            <field name="deadline"/>
            <field name="assigned_to"/>
            <field name="status"/>
            <templates>
                <t t-name="card">
                    <div class="o_kanban_record_top">
                        <div class="o_kanban_record_headings">
                            <strong class="o_kanban_record_title">
                                <field name="name"/>
                            </strong>
                        </div>
                    </div>
                    <div class="o_kanban_record_body">
                        <field name="assigned_to"/>
                        <br/>
                        <field name="deadline"/>
                    </div>
                </t>
            </templates>
        </kanban>
    </field>
</record>


    <!-- Task Form View -->
    <record id="view_emp_task_form" model="ir.ui.view">
        <field name="name">emp.task.form</field>
        <field name="model">emp.task</field>
        <field name="arch" type="xml">
            <form string="Task">
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="new,in_progress,done"/>
                </header>
                <sheet>
                    <group string="Task Info">
                        <field name="name"/>
                        <field name="assigned_to"/>
                    </group>
                    <group string="Work Info">
                            <field name="deadline"/>
                            <field name="status"/>
                    </group>
                    <group string="Description">
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_emp_task" model="ir.actions.act_window">
        <field name="name">Task</field>
        <field name="res_model">emp.task</field>
        <field name="view_mode">list,form</field>
        <field name="view_mode">list,form,kanban</field>

    </record>

</odoo>