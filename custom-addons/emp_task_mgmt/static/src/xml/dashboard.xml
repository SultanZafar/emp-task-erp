<?xml version="1.0" encoding="utf-8"?>
<templates>
    <t t-name="emp_task_mgmt.Dashboard">
        <div style="background:#0f172a;min-height:100vh;padding:24px;font-family:sans-serif;color:#f1f5f9">
            <div style="margin-bottom:20px">
                <h2 style="font-size:18px;font-weight:500;color:#f1f5f9;margin:0">Task Management Dashboard</h2>
                <p style="font-size:12px;color:#64748b;margin:4px 0 0">Employees · Tasks · Payroll</p>
            </div>
            <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:16px">
                <div t-on-click="openEmployeeList"
                     style="background:#1e293b;border:0.5px solid #334155;border-radius:10px;padding:16px;cursor:pointer"
                     onmouseenter="this.style.borderColor='#38bdf8'"
                     onmouseleave="this.style.borderColor='#334155'">
                    <div style="font-size:11px;color:#64748b;text-transform:uppercase;letter-spacing:0.5px">Employees</div>
                    <div style="font-size:28px;font-weight:500;color:#38bdf8;margin-top:6px"><t t-esc="state.total_employees"/></div>
                </div>
                <div t-on-click="openInProgress"
                     style="background:#1e293b;border:0.5px solid #334155;border-radius:10px;padding:16px;cursor:pointer"
                     onmouseenter="this.style.borderColor='#fb923c'"
                     onmouseleave="this.style.borderColor='#334155'">
                    <div style="font-size:11px;color:#64748b;text-transform:uppercase;letter-spacing:0.5px">In Progress</div>
                    <div style="font-size:28px;font-weight:500;color:#fb923c;margin-top:6px"><t t-esc="state.in_progress"/></div>
                </div>
                <div t-on-click="openDone"
                     style="background:#1e293b;border:0.5px solid #334155;border-radius:10px;padding:16px;cursor:pointer"
                     onmouseenter="this.style.borderColor='#4ade80'"
                     onmouseleave="this.style.borderColor='#334155'">
                    <div style="font-size:11px;color:#64748b;text-transform:uppercase;letter-spacing:0.5px">Completed</div>
                    <div style="font-size:28px;font-weight:500;color:#4ade80;margin-top:6px"><t t-esc="state.done_tasks"/></div>
                </div>
                <div t-on-click="openPayrollList"
                     style="background:#1e293b;border:0.5px solid #334155;border-radius:10px;padding:16px;cursor:pointer"
                     onmouseenter="this.style.borderColor='#f87171'"
                     onmouseleave="this.style.borderColor='#334155'">
                    <div style="font-size:11px;color:#64748b;text-transform:uppercase;letter-spacing:0.5px">Unpaid</div>
                    <div style="font-size:28px;font-weight:500;color:#f87171;margin-top:6px"><t t-esc="state.unpaid"/></div>
                </div>
            </div>
            <div style="background:#1e293b;border:0.5px solid #334155;border-radius:10px;padding:16px">
                <div style="font-size:11px;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:12px">Team Members</div>
                <div style="display:grid;grid-template-columns:2fr 1fr 1fr;gap:8px;padding-bottom:8px;border-bottom:0.5px solid #334155;margin-bottom:4px">
                    <div style="font-size:10px;color:#475569">Name</div>
                    <div style="font-size:10px;color:#475569">Department</div>
                    <div style="font-size:10px;color:#475569">Status</div>
                </div>
                <t t-foreach="state.employees" t-as="emp" t-key="emp.id">
                    <div t-on-click="openEmployee(emp.id)"
                         style="display:grid;grid-template-columns:2fr 1fr 1fr;gap:8px;padding:9px 0;border-bottom:0.5px solid #334155;cursor:pointer"
                         onmouseenter="this.style.background='rgba(56,189,248,0.05)'"
                         onmouseleave="this.style.background='transparent'">
                        <div style="font-size:13px;color:#38bdf8"><t t-esc="emp.name"/></div>
                        <div style="font-size:12px;color:#94a3b8"><t t-esc="emp.department"/></div>
                        <div><span style="font-size:10px;padding:2px 8px;border-radius:20px;background:#052e16;color:#4ade80"><t t-esc="emp.status"/></span></div>
                    </div>
                </t>
            </div>
        </div>
    </t>
</templates>